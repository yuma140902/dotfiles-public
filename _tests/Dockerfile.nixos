FROM nixos/nix:2.35.1@sha256:377d4887aca98f0dfa12971c1ea6d6a625a435d8b610d4c95a436843da6fbfd1
RUN echo 'experimental-features = nix-command flakes' >> /etc/nix/nix.conf

# remove pre-installed conflicting packages
RUN nix-env -e less man-db git-minimal wget curl

COPY .. /root/repos/dotfiles-public
